# ============================================================
# TaskFlow Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ============================================================

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL Database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskflow_dev
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT Authentication
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_very_long_random_secret_here
JWT_EXPIRES_IN=7d

# Password Hashing
# Higher = more secure but slower. 12 is a good production value.
BCRYPT_ROUNDS=12

# CORS - frontend origin
FRONTEND_URL=http://localhost:5500
